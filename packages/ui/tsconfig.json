{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "lib": ["ES2020", "DOM"],
        "moduleResolution": "Node",
        "rootDir": "src",
        "noEmit": true,

        "jsx": "react-jsx",

        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "isolatedModules": true,

        "strict": true,
        "skipLibCheck": true
    },
    "include": ["src"],
    "exclude": ["dist", "node_modules"]
}
