# ── Server ────────────────────────────────────────────────────────────────────
PORT=2611
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE=mongodb+srv://<USER>:<PASSWORD>@cluster.mongodb.net/rnb-auth?retryWrites=true&w=majority
DATABASE_PASSWORD=your_password_here

# ── SSO Session ───────────────────────────────────────────────────────────────
# Min 32 chars. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-session-secret-min-32-chars

# ── RS256 Key ID ──────────────────────────────────────────────────────────────
# Used as the `kid` in issued JWTs. Must match the key in keys/private.pem.
# Generate: node -e "console.log(require('crypto').randomBytes(8).toString('hex'))"
# See scripts/generateKeys.sh to create the RS256 key pair.
JWT_KEY_ID=your-key-id-hex

# ── Auth UI (rnb-auth Next.js app) ────────────────────────────────────────────
# Dev: http://localhost:3001 | Prod: https://auth.realmsandbeyond.com
AUTH_UI_URL=http://localhost:3001

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# ── Identity API (account portal — HS256 JWT cookies) ─────────────────────────
# These are used only by the /api/v1/user/* identity endpoints (rnb-auth account portal).
# NOT used for OAuth token signing (that uses the RS256 key pair in keys/).
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_COOKIE_SECRET=your-cookie-secret-min-16-chars
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:3000

# ── Cloudinary (optional — avatar uploads) ────────────────────────────────────
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_SECRET=your_api_secret
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
USER_DEFAULT_AVATAR=https://res.cloudinary.com/your_cloud/image/upload/v1/default.png

# ── Email (optional — verification emails) ────────────────────────────────────
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USERNAME=your_username
MAILTRAP_PASSWORD=your_password
