{
    "$schema": "https://turbo.build/schema.json",
    "ui": "tui",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
        },

        "dev": {
            "dependsOn": ["^build"],
            "cache": false,
            "persistent": true
        },

        "start": {
            "dependsOn": ["build"],
            "cache": false,
            "persistent": true
        },

        "lint": {
            "dependsOn": ["^build"],
            "outputs": []
        },

        "typecheck": {
            "dependsOn": ["^build"],
            "outputs": []
        },

        "clean": {
            "cache": false
        }
    }
}
